---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { SITE } from "../config";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });

const readingTime = (body) =>
  Math.max(1, Math.round((body ?? "").split(/\s+/).length / 220));
---
<Base>
  <section class="hero">
    <h1 set:html={SITE.tagline.replace(/actually read/i, "<em>actually read</em>")} />
    <p class="standfirst">{SITE.standfirst}</p>
  </section>

  {posts.length === 0 ? (
    <p class="empty">
      No posts yet. Write your first one at <code>/admin</code>, or add a markdown
      file to <code>src/content/posts/</code>.
    </p>
  ) : (
    <>
      <div class="ledger-head">
        <span>Position &middot; Thesis</span>
        <span>Conviction</span>
      </div>

      <ul class="ledger">
        {posts.map((post) => (
          <li class="row">
            <a href={`/posts/${post.id}`}>
              <span class="ticker">{post.data.ticker}</span>
              <span class="row-main">
                <h2>{post.data.title}</h2>
                <span class="meta">
                  {fmt(post.data.date)} &middot; {readingTime(post.body)} min
                </span>
              </span>
              <span class="conviction" data-level={post.data.conviction}>
                {post.data.conviction}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
